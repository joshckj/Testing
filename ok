def run_agent(messages: list, file_bytes: bytes = None, file_name: str = None) -> ChatResponse:
    try:
        last_message = messages[-1]["content"] if messages else ""

        if file_bytes and file_name:
            import base64
            file_b64 = base64.b64encode(file_bytes).decode()
            input_text = f"{last_message}\n\n[File attached: {file_name}]\n[file_bytes_b64: {file_b64}]"
        else:
            input_text = last_message

        result = agent_executor.invoke({
            "input": input_text,
            "chat_history": _build_chat_history(messages),
        })

        output = result["output"]

        if isinstance(output, dict) and "map_html" in output:
            return ChatResponse(
                message=output.get("message", "Analysis complete."),
                map_html=output.get("map_html"),
                csv_data=output.get("csv_data"),
            )

        if "please attach" in str(output).lower():
            return ChatResponse(message=output, requires_file=True)

        return ChatResponse(message=str(output))

    except Exception as e:
        # Print full traceback to logs
        import traceback
        traceback.print_exc()
        # Return clean message to frontend
        return ChatResponse(
            message=f"Error: {str(e)}",
            requires_file=False,
        )
