from langchain.chains import LLMChain
from langchain.prompts import PromptTemplate

# Simple conversational chain that can mention tools but doesn't force tool usage
conversational_prompt = PromptTemplate.from_template("""
You are a gas leak prediction assistant for SP Digital's Singapore pipe network. 

CAPABILITIES:
- Predict gas leak risk for the selected quarter and year across Singapore's hex grid

HOW TO USE:
For risk analysis: Tell me which quarter and year you want to predict, then upload a recent DMIS CSV.

RULES:
- Always be helpful and informative
- Only perform actions when explicitly requested. Do not execute without proper intent.
- Users cannot predict past quarters or > 4 years into the future. Reject those and ask for valid current/future ones.
- When a file is uploaded, tell them exactly: "Great, I have checked the data. There are months present [list found months] but you have some missing months [list missing months]. Do you still want to continue? the model can work still".
- Explain what you can do when asked
- Don't force tool usage - wait for user requests
- If do not know what they are saying, predict what they are saying and write it politely and ask do you mean this. 
                                                     

Current conversation:
{chat_history}

User: {input}

Assistant:""")

llm_chain = LLMChain(llm=llm, prompt=conversational_prompt)


def _build_chat_history(messages: list) -> list:
    history = []
    for msg in messages[:-1]:
        if msg["role"] == "user":
            history.append(HumanMessage(content=msg["content"]))
        elif msg["role"] == "assistant":
            history.append(AIMessage(content=msg["content"]))
    return history


def run_agent(messages: list, file_bytes: bytes = None, file_name: str = None) -> ChatResponse:
    try:
        # Create agent executor
        tools = [gasleakprediction_tool]
        agent = create_tool_calling_agent(llm, tools, prompt)
        agent_executor = AgentExecutor(agent=agent, tools=tools, verbose=True)
        
        last_message = messages[-1]["content"] if messages else ""

        # If a new file is uploaded, update the in-memory store.
        # This allows the file to persist across requests within a single user session
        # on a single worker process.
        if file_bytes and file_name:
            _file_store["file_bytes"] = file_bytes
            _file_store["file_name"] = file_name
            
            try:
                try:
                    df_temp = pd.read_csv(io.BytesIO(file_bytes), encoding="utf-8")
                except UnicodeDecodeError:
                    df_temp = pd.read_csv(io.BytesIO(file_bytes), encoding="latin-1")
                iquarter, iyear = _extract_period_from_df(df_temp)
                _file_store["detected_period"] = f"{iquarter} {iyear}"
                found_str, missing_str = _extract_months_from_df(df_temp)
                _file_store["detected_months"] = found_str
                _file_store["missing_months"] = missing_str
            except Exception:
                _file_store["detected_period"] = "Unknown"
                _file_store["detected_months"] = "Unknown"
                _file_store["missing_months"] = "Unknown"
        
        # Reset map and csv stores for this new run
        _file_store["map_html"] = None
        _file_store["csv_data"] = None

        if _file_store.get("file_bytes") and _file_store.get("file_name"):
            actual_period = _file_store.get("detected_period", "Unknown")
            detected_months = _file_store.get("detected_months", "Unknown")
            missing_months = _file_store.get("missing_months", "Unknown")
            input_text = f"{last_message}\n\n[File attached: {_file_store['file_name']}, size: {len(_file_store['file_bytes']):,} bytes, Actual data period: {actual_period}, Months found: {detected_months}, Missing expected months: {missing_months}]"
        else:
            input_text = last_message

        result = agent_executor.invoke({
            "input": input_text,
            "chat_history": _build_chat_history(messages),
        })

        output = result["output"]
        map_html = _file_store.get("map_html")
        csv_data = _file_store.get("csv_data")

        if map_html or csv_data:
            return ChatResponse(
                message=str(output),
                map_html=map_html,
                csv_data=csv_data,
            )

        if "please attach" in str(output).lower():
            return ChatResponse(message=output, requires_file=True)

        return ChatResponse(message=str(output))

    except Exception as e:
        import traceback
        traceback.print_exc()
        return ChatResponse(
            message=f"Error: {str(e)}",
            requires_file=False,
        )
