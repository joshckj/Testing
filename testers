def _get_expected_past_6_months():
    """Calculates the exact 6 months prior to the current date."""
    now = datetime.datetime.now()
    expected = []
    for i in range(1, 7):
        m = now.month - i
        y = now.year
        if m <= 0:
            m += 12
            y -= 1
        dt = datetime.datetime(y, m, 1)
        expected.append(dt.strftime('%b %Y'))
    return expected

def _extract_period_from_df(df: pd.DataFrame):
    if "Call end time" not in df.columns:
        raise ValueError("Missing 'Call end time' column to determine period.")
    # Coerce errors to handle empty rows and find the most common date to be resistant to outliers
    dates = pd.to_datetime(df["Call end time"], errors="coerce", dayfirst=True).dropna()
    if dates.empty:
        raise ValueError("Could not parse any valid dates from 'Call end time'.")

    input_year = str(int(dates.dt.year.mode()[0]))
    most_common_month = dates.dt.month.mode()[0]

    if most_common_month <= 3:
        input_quarter = "Q1"
    elif most_common_month <= 6:
        input_quarter = "Q2"
    elif most_common_month <= 9:
        input_quarter = "Q3"
    else:
        input_quarter = "Q4"

    return input_quarter, input_year

def _extract_months_from_df(df: pd.DataFrame):
    if "Call end time" not in df.columns:
        return "Unknown", "Unknown"
    dates = pd.to_datetime(df["Call end time"], errors="coerce", dayfirst=True).dropna()
    if dates.empty:
        return "Unknown", "Unknown"
    
    found_periods = dates.dt.to_period('M').unique()
    found_months = [p.strftime('%b %Y') for p in found_periods]
    
    expected_months = _get_expected_past_6_months()
    missing_months = [m for m in expected_months if m not in found_months]
    
    found_sorted = sorted(found_months, key=lambda x: datetime.datetime.strptime(x, '%b %Y'))
    missing_sorted = sorted(missing_months, key=lambda x: datetime.datetime.strptime(x, '%b %Y'))
    
    found_str = ", ".join(found_sorted) if found_sorted else "None"
    missing_str = ", ".join(missing_sorted) if missing_sorted else "None"
    return found_str, missing_str

# ── Tools ──────────────────────────────────────────────────────────────────────

@tool
def gasleakprediction_tool(
    prediction_quarter: str,
    prediction_year: str,
    high_threshold: float = 3.0,
    medium_threshold: float = 2.0,
    low_threshold: float = 1.0,
) -> dict:
    """
    Predicts gas leak risk for the specified quarter/year across Singapore's hex grid.
    Requires a recent DMIS CSV file to base the predictions on.

    Parameters
    ----------
    prediction_quarter : "Q1", "Q2", "Q3", or "Q4" — the quarter to predict
    prediction_year    : 4-digit year string, e.g. "2026"
    high_threshold     : leaks >= this -> High risk (default 3.0)
    medium_threshold   : leaks >= this -> Medium risk (default 2.0)
    low_threshold      : leaks >= this -> Low risk (default 1.0)

    Rules
    -----
    - Always confirm prediction_quarter and prediction_year with the user before calling.
    - Thresholds must satisfy: high > medium > low.
    - File must be attached before calling.
    """
    now = datetime.datetime.now()
    current_year = now.year
    current_quarter = (now.month - 1) // 3 + 1
    
    try:
        pred_year_int = int(prediction_year)
        pred_q_int = int(prediction_quarter.upper().replace("Q", ""))
        if pred_year_int < current_year or (pred_year_int == current_year and pred_q_int < current_quarter):
            return {"message": f"Error: You cannot predict past quarters ({prediction_quarter} {prediction_year}). Please specify a current or future quarter (e.g., Q{current_quarter} {current_year} or later)."}
        if pred_year_int > current_year + 4:
            return {"message": f"Error: You cannot predict more than 4 years into the future. The maximum allowed year is {current_year + 4}."}
    except ValueError:
        pass

    file_bytes = _file_store["file_bytes"]
    file_name = _file_store["file_name"]

    if not file_bytes:
        return {"message": "Please attach a DMIS CSV file first."}

    tmp_path = f"/tmp/{file_name or 'uploaded.csv'}"
    with open(tmp_path, "wb") as f:
        f.write(file_bytes)

    result = gasleakprediction(tmp_path, prediction_quarter, prediction_year, high_threshold, medium_threshold, low_threshold)

    _file_store["map_html"] = result.get("map_output")
    _file_store["csv_data"] = result.get("csv_data")

    return {"status": f"Analysis complete. Prediction for {prediction_quarter} {prediction_year}."}


@tool
def ingest_newdata_tool() -> str:
    """
    Ingests a new DMIS CSV file into PostgreSQL.
    Automatically removes duplicate DMIR Numbers (within file and vs database).
    Developer-facing only.

    Rules
    -----
    - Always confirm file is attached before calling.
    - Report back exactly how many records were inserted and how many were duplicates.
    """
    # Read file bytes from agent_executor — not from LLM input
    file_bytes = _file_store["file_bytes"]
    file_name = _file_store["file_name"]

    if not file_bytes:
        return "Please attach a DMIS CSV file first."

    try:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="utf-8")
    except UnicodeDecodeError:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="latin-1")

    try:
        input_quarter, input_year = _extract_period_from_df(df)
    except ValueError as e:
        return str(e)

    return run_ingest_newdata(file_bytes, file_name or "uploaded.csv", input_quarter, input_year)


