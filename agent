<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gas Leak Agent — SP Digital</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Syne:wght@400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #231c19;
    --surface: #2d2420;
    --border: #423630;
    --accent: #d4a373;
    --accent-dim: rgba(212, 163, 115, 0.1);
    --accent-mid: rgba(212, 163, 115, 0.3);
    --text: #f0e9e4;
    --text-dim: #9e8e86;
    --text-mid: #c7b8b0;
    --danger: #e06666;
    --warning: #e6b065;
    --user-bg: #3b302a;
    --agent-bg: #28201c;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Header */
  header {
    padding: 16px 28px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    flex-shrink: 0;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: var(--accent);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-icon svg { width: 18px; height: 18px; }

  .logo-text {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .logo-sub {
    font-size: 11px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    font-weight: 300;
    letter-spacing: 0.08em;
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--accent-dim);
    border: 1px solid var(--accent-mid);
    border-radius: 20px;
    padding: 4px 12px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Chat area */
  .chat-container {
    flex: 1;
    overflow-y: auto;
    padding: 24px 0;
    scroll-behavior: smooth;
  }

  .chat-container::-webkit-scrollbar { width: 4px; }
  .chat-container::-webkit-scrollbar-track { background: transparent; }
  .chat-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  .message-wrapper {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 24px;
    animation: fadeUp 0.3s ease;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .message {
    margin-bottom: 24px;
  }

  .message-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    font-weight: 600;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
  }

  .avatar.agent {
    background: var(--accent-dim);
    border: 1px solid var(--accent-mid);
    color: var(--accent);
  }

  .avatar.user {
    background: #362a24;
    border: 1px solid #4a3b33;
    color: var(--text-mid);
  }

  .sender-name {
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .message-bubble {
    padding: 14px 18px;
    border-radius: 12px;
    font-size: 14px;
    line-height: 1.7;
    border: 1px solid transparent;
  }

  .message-bubble.agent {
    background: var(--agent-bg);
    border-color: var(--border);
    color: var(--text);
    margin-right: 40px;
  }

  .message-bubble.user {
    background: var(--user-bg);
    border-color: var(--border);
    color: var(--text-mid);
    margin-left: 40px;
  }

  /* Map iframe */
  .map-container {
    margin-top: 16px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    height: 400px;
  }

  .map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  /* CSV download button */
  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 8px 16px;
    background: var(--accent-dim);
    border: 1px solid var(--accent-mid);
    border-radius: 8px;
    color: var(--accent);
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.04em;
  }

  .download-btn:hover {
    background: var(--accent-mid);
  }

  /* Typing indicator */
  .typing {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 14px 18px;
    background: var(--agent-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-right: 40px;
    width: fit-content;
  }

  .typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: typing 1.2s infinite;
  }

  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes typing {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30%           { transform: translateY(-4px); opacity: 1; }
  }

  /* Welcome screen */
  .welcome {
    max-width: 780px;
    margin: 40px auto 0;
    padding: 0 24px;
  }

  .welcome-title {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }

  .welcome-title span { color: var(--accent); }

  .welcome-sub {
    font-size: 14px;
    color: var(--text-dim);
    margin-bottom: 16px;
    line-height: 1.6;
  }

  /* Input area */
  .input-area {
    border-top: 1px solid var(--border);
    background: var(--surface);
    padding: 16px 24px;
    flex-shrink: 0;
  }

  .input-inner {
    max-width: 780px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .file-upload-area {
    display: none;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--bg);
    border: 1px dashed var(--border);
    border-radius: 8px;
    font-size: 12px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
  }

  .file-upload-area.visible { display: flex; }

  .file-upload-area.has-file {
    border-color: var(--accent-mid);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .file-input { display: none; }

  .file-btn {
    padding: 4px 10px;
    background: var(--border);
    border: none;
    border-radius: 4px;
    color: var(--text-mid);
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .file-btn:hover { background: #4a3c35; color: var(--text); }

  .input-row {
    display: flex;
    gap: 10px;
    align-items: flex-end;
  }

  textarea {
    flex: 1;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    resize: none;
    outline: none;
    min-height: 44px;
    max-height: 120px;
    line-height: 1.5;
    transition: border-color 0.2s;
  }

  textarea:focus { border-color: var(--accent-mid); }
  textarea::placeholder { color: var(--text-dim); }

  .send-btn {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .send-btn:hover { background: #c39262; transform: scale(1.05); }
  .send-btn:active { transform: scale(0.97); }
  .send-btn:disabled { background: var(--border); cursor: not-allowed; transform: none; }

  .send-btn svg { width: 18px; height: 18px; }

  .attach-btn {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--bg);
    border: 1px solid var(--border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    flex-shrink: 0;
    color: var(--text-dim);
  }

  .attach-btn:hover { border-color: var(--accent-mid); color: var(--accent); }
  .attach-btn svg { width: 18px; height: 18px; }

  .input-hint {
    font-size: 11px;
    color: var(--text-dim);
    font-family: 'JetBrains Mono', monospace;
    text-align: center;
    letter-spacing: 0.04em;
  }

  /* Error message */
  .error-bubble {
    padding: 10px 14px;
    background: #2b1c1a;
    border: 1px solid #4a2824;
    border-radius: 8px;
    color: var(--danger);
    font-size: 13px;
    font-family: 'JetBrains Mono', monospace;
    margin-top: 8px;
  }
</style>
</head>
<body>

<!-- Header -->
<header>
  <div class="logo">
    <div class="logo-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
        <path d="M12 6v6l4 2"/>
      </svg>
    </div>
    <div>
      <div class="logo-text">Gas Leak Agent</div>
      <div class="logo-sub">SP DIGITAL · SINGAPORE</div>
    </div>
  </div>
  <div class="status-pill">
    <div class="status-dot"></div>
    ONLINE
  </div>
</header>

<!-- Chat area -->
<div class="chat-container" id="chatContainer">

  <!-- Welcome screen -->
  <div class="welcome" id="welcomeScreen">
    <div class="welcome-title">Hello. I'm your<br><span>Gas Leak Analyst.</span></div>
    <div class="welcome-sub">
      Upload a 6-month DMIS CSV to predict gas leak risk across Singapore's pipe network.
      I'll generate an interactive hex map and risk breakdown.
    </div>
  </div>

  <!-- Messages will appear here -->
  <div id="messages"></div>

</div>

<!-- Input area -->
<div class="input-area">
  <div class="input-inner">

    <!-- File upload row -->
    <div class="file-upload-area" id="fileUploadArea">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
      </svg>
      <span id="fileLabel">No file selected — click to attach CSV</span>
      <button class="file-btn" onclick="document.getElementById('fileInput').click()">Browse</button>
      <button class="file-btn" onclick="clearFile()" style="display:none" id="clearFileBtn">Remove</button>
      <input type="file" id="fileInput" class="file-input" accept=".csv" onchange="handleFile(this)">
    </div>

    <div class="input-row">
      <button class="attach-btn" onclick="toggleFileUpload()" title="Attach CSV file">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/>
        </svg>
      </button>
      <textarea
        id="messageInput"
        placeholder="Type a message..."
        rows="1"
        onkeydown="handleKey(event)"
        oninput="autoResize(this)"
      ></textarea>
      <button class="send-btn" id="sendBtn" onclick="sendMessage()">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--bg)" stroke-width="2.5" stroke-linecap="round">
          <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/>
        </svg>
      </button>
    </div>

    <div class="input-hint">GASLEAKAGENT v3 · localhost:8000</div>
  </div>
</div>

<script>
  // ── Config ──────────────────────────────────────────────────────────────────
  const API_URL      = "/api/v1/chat";
  let   chatHistory  = [];
  let   selectedFile = null;
  let   isLoading    = false;

  // ── File handling ────────────────────────────────────────────────────────────
  function toggleFileUpload() {
    const area = document.getElementById("fileUploadArea");
    area.classList.toggle("visible");
  }

  function handleFile(input) {
    if (input.files && input.files[0]) {
      selectedFile = input.files[0];
      const area  = document.getElementById("fileUploadArea");
      const label = document.getElementById("fileLabel");
      const clear = document.getElementById("clearFileBtn");
      label.textContent = selectedFile.name;
      area.classList.add("has-file");
      clear.style.display = "block";
    }
  }

  function clearFile() {
    selectedFile = null;
    document.getElementById("fileInput").value = "";
    document.getElementById("fileLabel").textContent = "No file selected — click to attach CSV";
    document.getElementById("fileUploadArea").classList.remove("has-file");
    document.getElementById("clearFileBtn").style.display = "none";
  }

  // ── Auto resize textarea ─────────────────────────────────────────────────────
  function autoResize(el) {
    el.style.height = "auto";
    el.style.height = Math.min(el.scrollHeight, 120) + "px";
  }

  // ── Key handler ──────────────────────────────────────────────────────────────
  function handleKey(e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  }

  // ── Suggestions ──────────────────────────────────────────────────────────────
  function sendSuggestion(text) {
    document.getElementById("messageInput").value = text;
    sendMessage();
  }

  // ── Send message ─────────────────────────────────────────────────────────────
  async function sendMessage() {
    const input = document.getElementById("messageInput");
    const text  = input.value.trim();
    if (!text || isLoading) return;

    // Hide welcome screen
    document.getElementById("welcomeScreen").style.display = "none";

    // Add user message to UI
    appendMessage("user", text);

    // Add to history
    chatHistory.push({ role: "user", content: text });

    // Clear input
    input.value = "";
    input.style.height = "auto";

    // Show typing
    const typingId = showTyping();
    setLoading(true);

    try {
      // Build form data
      const formData = new FormData();
      formData.append("messages", JSON.stringify(chatHistory));
      if (selectedFile) {
        formData.append("file", selectedFile);
      }

      const response = await fetch(API_URL, {
        method: "POST",
        body: formData,
      });

      const data = await response.json();

      removeTyping(typingId);

      if (!response.ok) {
        appendError(data.detail || "Something went wrong. Please try again.");
        return;
      }

      // Add agent message
      appendMessage("agent", data.message, data.map_html, data.csv_data);

      // Add to history
      chatHistory.push({ role: "assistant", content: data.message });

      // Show file upload if agent needs a file
      if (data.requires_file) {
        document.getElementById("fileUploadArea").classList.add("visible");
      }

      // Clear file after sending
      if (selectedFile) clearFile();

    } catch (err) {
      removeTyping(typingId);
      appendError(`Cannot reach backend at ${API_URL}. Is gasleakagent running?`);
    } finally {
      setLoading(false);
    }
  }

  // ── Append message ───────────────────────────────────────────────────────────
  function appendMessage(role, text, mapHtml = null, csvData = null) {
    const messages = document.getElementById("messages");

    const wrapper = document.createElement("div");
    wrapper.className = "message-wrapper";

    const msg = document.createElement("div");
    msg.className = "message";

    const header = document.createElement("div");
    header.className = "message-header";

    const avatar = document.createElement("div");
    avatar.className = `avatar ${role}`;
    avatar.textContent = role === "agent" ? "GA" : "YOU";

    const name = document.createElement("div");
    name.className = "sender-name";
    name.textContent = role === "agent" ? "GAS LEAK AGENT" : "YOU";

    header.appendChild(avatar);
    header.appendChild(name);

    const bubble = document.createElement("div");
    bubble.className = `message-bubble ${role}`;
    bubble.innerHTML = formatText(text);

    msg.appendChild(header);
    msg.appendChild(bubble);

    // Map
    if (mapHtml) {
      const mapContainer = document.createElement("div");
      mapContainer.className = "map-container";
      const iframe = document.createElement("iframe");
      iframe.srcdoc = mapHtml;
      iframe.setAttribute("sandbox", "allow-scripts allow-same-origin");
      mapContainer.appendChild(iframe);
      msg.appendChild(mapContainer);
    }

    // CSV download
    if (csvData) {
      const btn = document.createElement("button");
      btn.className = "download-btn";
      btn.innerHTML = `
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
        </svg>
        DOWNLOAD PREDICTION CSV
      `;
      btn.onclick = () => downloadCSV(csvData);
      msg.appendChild(btn);
    }

    wrapper.appendChild(msg);
    messages.appendChild(wrapper);
    scrollToBottom();
  }

  // ── Append error ─────────────────────────────────────────────────────────────
  function appendError(text) {
    const messages = document.getElementById("messages");
    const wrapper  = document.createElement("div");
    wrapper.className = "message-wrapper";
    const err = document.createElement("div");
    err.className = "error-bubble";
    err.textContent = `⚠ ${text}`;
    wrapper.appendChild(err);
    messages.appendChild(wrapper);
    scrollToBottom();
  }

  // ── Typing indicator ─────────────────────────────────────────────────────────
  function showTyping() {
    const messages = document.getElementById("messages");
    const wrapper  = document.createElement("div");
    const id       = "typing-" + Date.now();
    wrapper.id     = id;
    wrapper.className = "message-wrapper";

    const header = document.createElement("div");
    header.className = "message-header";
    const avatar = document.createElement("div");
    avatar.className = "avatar agent";
    avatar.textContent = "GA";
    const name = document.createElement("div");
    name.className = "sender-name";
    name.textContent = "GAS LEAK AGENT";
    header.appendChild(avatar);
    header.appendChild(name);

    const typing = document.createElement("div");
    typing.className = "typing";
    typing.innerHTML = "<span></span><span></span><span></span>";

    wrapper.appendChild(header);
    wrapper.appendChild(typing);
    messages.appendChild(wrapper);
    scrollToBottom();
    return id;
  }

  function removeTyping(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }

  // ── Helpers ──────────────────────────────────────────────────────────────────
  function formatText(text) {
    return text
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\n/g, "<br>")
      .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
  }

  function downloadCSV(csvData) {
    const blob = new Blob([csvData], { type: "text/csv" });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement("a");
    a.href     = url;
    a.download = `gas_leak_prediction_${new Date().toISOString().slice(0,10)}.csv`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  function setLoading(val) {
    isLoading = val;
    document.getElementById("sendBtn").disabled = val;
  }

  function scrollToBottom() {
    const container = document.getElementById("chatContainer");
    container.scrollTop = container.scrollHeight;
  }
</script>
</body>
</html>
