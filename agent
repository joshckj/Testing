from langchain.agents import AgentExecutor, create_tool_calling_agent
from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder
from langchain_core.messages import HumanMessage, AIMessage
from langchain_core.tools import tool
from app.core.llm import llm
from app.skills.hex_assigner.scripts.main import run_hex_assigner
from app.skills.validation.scripts.main import run_validation
from app.skills.analysis_map.main import run_analysis_map
from app.skills.ingest_newdata.scripts.main import run_ingest_newdata
from app.utils.models import ChatResponse

_file_store = {
    "file_bytes": None,
    "file_name": None,
    "map_html": None,
    "csv_data": None,
    "detected_period": None,
}

def _extract_period_from_df(df: pd.DataFrame):
    if "Call end time" not in df.columns:
        raise ValueError("Missing 'Call end time' column to determine period.")
    # Coerce errors to handle empty rows and find the most common date to be resistant to outliers
    dates = pd.to_datetime(df["Call end time"], errors="coerce", dayfirst=True).dropna()
    if dates.empty:
        raise ValueError("Could not parse any valid dates from 'Call end time'.")
    
    input_year = str(int(dates.dt.year.mode()[0]))
    most_common_month = dates.dt.month.mode()[0]
    input_half = "H1" if most_common_month <= 6 else "H2"
    
    return input_half, input_year

# ── Tools ──────────────────────────────────────────────────────────────────────

@tool
def analysis_map_tool(
    high_threshold: float = 25.0,
    medium_threshold: float = 15.0,
    low_threshold: float = 5.0,
) -> dict:
    """
    Predicts gas leak risk for the NEXT 6 months across Singapore's hex grid.

    Parameters
    ----------
    high_threshold   : leaks >= this -> High risk (default 25.0)
    medium_threshold : leaks >= this -> Medium risk (default 15.0)
    low_threshold    : leaks >= this -> Low risk (default 5.0)

    Rules
    -----
    - Always confirm thresholds before calling.
    - Thresholds must satisfy: high > medium > low.
    - File must be attached before calling.
    """
    # Read file bytes from agent_executor — not from LLM input
    file_bytes = _file_store["file_bytes"]
    file_name = _file_store["file_name"]

    if not file_bytes:
        return {"message": "Please attach a 6-month DMIS CSV file first."}

    try:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="utf-8")
    except UnicodeDecodeError:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="latin-1")

    try:
        input_half, input_year = _extract_period_from_df(df)
    except ValueError as e:
        return {"message": str(e)}

    df = run_hex_assigner(df)
    df, validation_report = run_validation(df, input_half, input_year)
    result = run_analysis_map(df, input_half, input_year, high_threshold, medium_threshold, low_threshold)
    
    # Pop large outputs out of the dictionary so we don't blow up the LLM token context limit
    _file_store["map_html"] = result.pop("map_html", None)
    _file_store["csv_data"] = result.pop("csv_data", None)
    
    result["validation_report"] = validation_report
    return result


@tool
def ingest_newdata_tool() -> str:
    """
    Ingests a new DMIS CSV file into PostgreSQL.
    Automatically removes duplicate DMIR Numbers (within file and vs database).
    Developer-facing only.

    Rules
    -----
    - Always confirm file is attached before calling.
    - Report back exactly how many records were inserted and how many were duplicates.
    """
    # Read file bytes from agent_executor — not from LLM input
    file_bytes = _file_store["file_bytes"]
    file_name = _file_store["file_name"]

    if not file_bytes:
        return "Please attach a DMIS CSV file first."

    try:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="utf-8")
    except UnicodeDecodeError:
        df = pd.read_csv(io.BytesIO(file_bytes), encoding="latin-1")

    try:
        input_half, input_year = _extract_period_from_df(df)
    except ValueError as e:
        return str(e)

    return run_ingest_newdata(file_bytes, file_name or "uploaded.csv", input_half, input_year)


